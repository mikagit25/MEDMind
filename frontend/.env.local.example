NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key

# PostHog analytics — https://posthog.com → your project → Project Settings → API Key
# Leave empty in development to disable analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry — get DSN from https://sentry.io → your project → Client Keys
# Leave empty in development to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=
# Only needed for CI source-map upload (sentry-cli)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=medmind-frontend
