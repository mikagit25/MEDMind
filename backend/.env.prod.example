# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
ENABLE_DOCS=false
VERSION=1.0.0
ALLOWED_ORIGINS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN

# ── Database ─────────────────────────────────────────────────────────────────
# Set via docker-compose environment (DATABASE_URL built from POSTGRES_* vars)
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@postgres:5432/medmind

# ── Redis ────────────────────────────────────────────────────────────────────
# Set via docker-compose environment (REDIS_URL built from REDIS_PASSWORD var)
# REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=GENERATE_WITH__python_-c__import_secrets;print(secrets.token_hex(32))
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-production-key
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN/api/v1/auth/google/callback

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-live-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-live-webhook-secret

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=MedMind AI <noreply@YOUR_DOMAIN>
FRONTEND_URL=https://YOUR_DOMAIN

# ── Content ──────────────────────────────────────────────────────────────────
MODULES_DIR=/app/data/modules
PUBMED_API_KEY=

# ── Security / Encryption (GDPR) ─────────────────────────────────────────────
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── AI Rate Limits ─────────────────────────────────────────────────────────────
AI_LIMIT_FREE=5
AI_LIMIT_STUDENT=50

# ── Push Notifications ─────────────────────────────────────────────────────────
EXPO_PROJECT_ID=your-expo-project-id
