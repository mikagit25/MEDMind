# ── MedMind AI — Backend production environment ─────────────────────────────
# Copy to backend/.env.prod and fill real values:
#   cp backend/.env.prod.example backend/.env.prod && nano backend/.env.prod

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
ENABLE_DOCS=false
VERSION=1.0.0
ALLOWED_ORIGINS=https://medmind.pro,https://www.medmind.pro
FRONTEND_URL=https://medmind.pro

# ── Database ─────────────────────────────────────────────────────────────────
# Injected by docker-compose via DATABASE_URL env var — no need to set here
# DATABASE_URL=postgresql+asyncpg://medmind:PASSWORD@postgres:5432/medmind

# ── Redis ────────────────────────────────────────────────────────────────────
# Injected by docker-compose via REDIS_URL env var — no need to set here
# REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=GENERATE_WITH__python3_-c__import_secrets_print_secrets.token_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-production-key
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://medmind.pro/api/v1/auth/google/callback

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-live-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-live-webhook-secret

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@medmind.pro
SMTP_PASSWORD=your-app-password
EMAIL_FROM=MedMind AI <noreply@medmind.pro>

# ── Content ──────────────────────────────────────────────────────────────────
MODULES_DIR=/app/data/modules
MEDIA_ROOT=/app/data/media
MEDIA_URL=/media
PUBMED_API_KEY=

# ── Security / Encryption (GDPR) ─────────────────────────────────────────────
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── AI Rate Limits ─────────────────────────────────────────────────────────────
AI_LIMIT_FREE=5
AI_LIMIT_STUDENT=50

# ── Push Notifications (Expo) ──────────────────────────────────────────────────
EXPO_PROJECT_ID=your-expo-project-id
