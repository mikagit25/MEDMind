# ── docker-compose.prod.yml variables ──────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env && nano .env

# PostgreSQL
POSTGRES_USER=medmind
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=medmind

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# Public API URL — must match domain exactly
NEXT_PUBLIC_API_URL=https://medmind.pro/api/v1
